# Required Matrix settings
MATRIX_HOMESERVER_URL=https://matrix.example.com
MATRIX_ACCESS_TOKEN=your_bot_access_token_here
MATRIX_BOT_USER_ID=@assistantbot:matrix.example.com

# Optional allow-list. Comma-separated Matrix user IDs.
# If empty, anyone in rooms with the bot can run integration commands.
MATRIX_ALLOWED_USERS=@you:matrix.example.com

# Google Calendar (optional, required for !calendar today)
# Use a Google service account and share your calendar with that service account email.
GOOGLE_CALENDAR_CLIENT_EMAIL=service-account-name@project-id.iam.gserviceaccount.com
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nYOUR_KEY_LINE_1\\nYOUR_KEY_LINE_2\\n-----END PRIVATE KEY-----\\n"
GOOGLE_CALENDAR_ID=primary

# Trello (optional, required for !trello due)
TRELLO_API_KEY=your_trello_api_key
TRELLO_API_TOKEN=your_trello_api_token
TRELLO_BOARD_ID=your_board_id

PORT=3000

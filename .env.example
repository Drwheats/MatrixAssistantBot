# Required Matrix settings
MATRIX_HOMESERVER_URL=https://matrix.example.com
MATRIX_ACCESS_TOKEN=your_bot_access_token_here
MATRIX_BOT_USER_ID=@assistantbot:matrix.example.com

# Optional allow-list. Comma-separated Matrix user IDs.
# If empty, anyone in rooms with the bot can run integration commands.
MATRIX_ALLOWED_USERS=@you:matrix.example.com

# Google Calendar (optional, required for !calendar today)
# Use a Google service account and share your calendar with that service account email.
GOOGLE_CALENDAR_CLIENT_EMAIL=service-account-name@project-id.iam.gserviceaccount.com
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nYOUR_KEY_LINE_1\\nYOUR_KEY_LINE_2\\n-----END PRIVATE KEY-----\\n"
GOOGLE_CALENDAR_ID=primary

# Trello (optional, required for !trello due)
TRELLO_API_KEY=your_trello_api_key
TRELLO_API_TOKEN=your_trello_api_token
TRELLO_BOARD_ID=your_board_id
# Optional: list ID used by !trello create. If omitted, bot uses first open list on board.
TRELLO_DEFAULT_LIST_ID=

# Grafana (optional, required for !grafana commands)
GRAFANA_URL=https://grafana.example.com
GRAFANA_TOKEN=your_grafana_api_token
GRAFANA_LOKI_DATASOURCE_UID=your_loki_datasource_uid
# Optional label selector for log queries (default: {})
GRAFANA_LOG_LABEL_SELECTOR={app="api"}
# Optional service label used for incident grouping (default: service)
GRAFANA_INCIDENT_SERVICE_LABEL=service
# Optional: enable SSH password login alerts posted to Grafana Alerts room.
# Defaults to enabled when GRAFANA_SECURITY_LOGIN_QUERY is set.
GRAFANA_SECURITY_LOGIN_ALERTS_ENABLED=true
# Optional: override Loki query for SSH password logins.
# Default: {selector} |~ "(?i)sshd" |~ "(?i)accepted password"
GRAFANA_SECURITY_LOGIN_QUERY=
# Optional: override label selector just for security login alerts.
GRAFANA_SECURITY_LOGIN_LABEL_SELECTOR={host="mushroom"}
# Optional: polling interval and lookback window in milliseconds.
GRAFANA_SECURITY_LOGIN_POLL_MS=15000
GRAFANA_SECURITY_LOGIN_LOOKBACK_MS=300000
GRAFANA_SECURITY_LOGIN_LIMIT=50

# Optional: qbittorrent alerts from Grafana Loki logs
GRAFANA_QBITTORRENT_ALERTS_ENABLED=false
# Optional: label selector for qbittorrent logs (falls back to GRAFANA_LOG_LABEL_SELECTOR or {})
GRAFANA_QBITTORRENT_LABEL_SELECTOR={app="qbittorrent"}
GRAFANA_QBITTORRENT_POLL_MS=15000
GRAFANA_QBITTORRENT_LOOKBACK_MS=300000
GRAFANA_QBITTORRENT_LIMIT=50

# LLM Studio (optional, required for !blimpf and !factcheck)
# Use 127.0.0.1 if the bot runs on the same machine as LLM Studio.
# For another machine on your LAN, use its IP (example: http://192.168.2.61:1234).
LLM_STUDIO_BASE_URL=http://127.0.0.1:1234
# Required: model name loaded in LLM Studio (example: "llama3.1:8b-instruct")
LLM_STUDIO_MODEL=meta-llama-3.1-8b-instruct
# Optional: only if you enabled auth in LLM Studio
LLM_STUDIO_API_KEY=
# Optional tuning
LLM_STUDIO_TEMPERATURE=0.2
LLM_STUDIO_MAX_TOKENS=700
LLM_STUDIO_TIMEOUT_MS=30000

PORT=3000

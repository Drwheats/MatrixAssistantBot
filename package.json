  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langchain/core": "^1.1.33",
    "@langchain/openai": "^1.3.0",
    "@types/node": "^22.13.9",
    "dotenv": "^16.4.7",
    "googleapis": "^149.0.0",
    "matrix-bot-sdk": "^0.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

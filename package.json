{
  "name": "matrix-assistant-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Matrix assistant bot with Google Calendar and Trello integrations",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "test": "node --test --import tsx src/**/*.test.ts"
